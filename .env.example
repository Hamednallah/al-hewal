# =============================================================================
# Al Hewal — environment variables (TEMPLATE)
#
# Copy this file to `.env.local` for local development and fill in real values.
# NEVER commit `.env.local` or any file containing real secrets — `.gitignore`
# blocks them.
#
# In production, these are managed via Vercel project environment variables
# (Production / Preview / Development scopes). See SECURITY.md for the
# rotation schedule.
# =============================================================================

# ----- Public site URL -------------------------------------------------------
# Used for canonical URLs, OG image generation, hreflang alternates,
# and CSRF Origin checks. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Supabase --------------------------------------------------------------
# Get from https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — SERVER ONLY. Never exposed to the browser. Used only
# inside src/lib/supabase/admin.ts (guarded by `import 'server-only'`).
# Rotate quarterly. See SECURITY.md.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----- Vercel Blob -----------------------------------------------------------
# Get from Vercel dashboard -> Storage -> Blob -> .env.local
# Read+Write token; rotate quarterly.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ----- WhatsApp lead capture -------------------------------------------------
# The phone number that wa.me links to. E.164 format, no + sign in the URL.
# Example for KSA: 9665XXXXXXXX
NEXT_PUBLIC_WHATSAPP_PHONE=9665XXXXXXXX

# ----- Maps ------------------------------------------------------------------
# Phase 1-2 uses MapLibre GL + OpenStreetMap tiles — no API key required.
# When the owner wants Google's tile imagery, set NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# below and the property-detail page will switch providers.
#
# Get key from: https://console.cloud.google.com/google/maps-apis/credentials
# Restrict by HTTP referrer to the production domain before going live.
# Quota: $200/month credit; Embed API is free per docs.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ----- Upstash Redis (rate limiting) -----------------------------------------
# Get from https://console.upstash.com/redis/<db>?tab=details
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ----- Admin session cookie HMAC secret (Phase 3) ----------------------------
# Signs the 1-hour admin session cookie so middleware can authorise admin
# routes without round-tripping to Supabase on every request.
#
# Generate a fresh 32-byte hex string. Pick whichever shell you have:
#   bash / WSL / mac:  openssl rand -hex 32
#   PowerShell:        -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Maximum 16) })
#   Node REPL:         require('crypto').randomBytes(32).toString('hex')
#
# Rotate quarterly per SECURITY.md. Rotation forces active admins to sign in
# again once — no other side-effect.
AUTH_COOKIE_SECRET=replace-with-64-hex-chars-from-openssl-rand-hex-32

# ----- Sentry (deferred) -----------------------------------------------------
# Originally planned for Phase 5 but DROPPED during PR 5-B scoping:
# zero production traffic + one operator + existing error boundaries
# + Vercel's built-in logs cover the use case today. Revisit when
# traffic justifies aggregated client-side error reporting.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ----- Resend (fallback email — Phase 4) -------------------------------------
# Used only if Supabase Auth's built-in email sending hits limits.
RESEND_API_KEY=
