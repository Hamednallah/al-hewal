# ============================================================================
# Al Hewal — npm/pnpm configuration
#
# This file enforces the supply-chain hardening policy documented in
# SECURITY.md. Do not loosen these settings without a security review.
# ============================================================================

# --- Supply-chain hardening --------------------------------------------------

# Disable ALL postinstall / prepublish / preuninstall etc. scripts by default.
# This was the propagation vector for the Sept 2025 Shai-Hulud npm worm.
# Packages that genuinely need to run a build step (sharp, esbuild, ...)
# must be opted in via `pnpm.onlyBuiltDependencies` in package.json.
ignore-scripts=true

# Refuse to install any package version published less than 7 days ago.
# Catches most malicious publishes before they spread (Shai-Hulud, chalk,
# debug, eslint-config-prettier compromises were all flagged within 72h).
# Requires pnpm >= 10.10.
minimum-release-age=10080

# Always require an existing, up-to-date lockfile. Fails the install if the
# lockfile is missing or out of sync with package.json. Equivalent of
# `pnpm install --frozen-lockfile`. CI inherits this automatically.
prefer-frozen-lockfile=true

# Verify the integrity of every fetched tarball against the lockfile's
# integrity hashes. Detects tampered cache entries.
verify-store-integrity=true

# Refuse to silently auto-install or auto-upgrade peer dependencies.
# Forces conscious resolution of peer mismatches at PR review time.
auto-install-peers=false
strict-peer-dependencies=true

# Forbid loose link: dependencies in production deps without explicit opt-in.
prefer-symlinked-executables=true

# --- Reproducibility ---------------------------------------------------------

# Use a deterministic, isolated node_modules layout (default in pnpm 8+, but
# stated explicitly for documentation).
node-linker=isolated

# Save exact versions when running `pnpm add`; never write ^ or ~ ranges.
save-exact=true
save-prefix=

# Always save into the appropriate dependencies bucket; never save to
# optionalDependencies without explicit --save-optional.
save-workspace-protocol=rolling

# --- Diagnostics & UX --------------------------------------------------------

# Surface deprecation notices so we replace deprecated packages quickly.
report-summary=true
loglevel=warn

# --- Registry ----------------------------------------------------------------

registry=https://registry.npmjs.org/
