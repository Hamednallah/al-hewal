{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(git stash list:*)",
      "Bash(git remote -v)",

      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git push origin feat/*)",
      "Bash(git push origin fix/*)",
      "Bash(git push origin chore/*)",
      "Bash(git push origin docs/*)",
      "Bash(git push origin test/*)",
      "Bash(git push -u origin feat/*)",
      "Bash(git push -u origin fix/*)",
      "Bash(git push -u origin chore/*)",
      "Bash(git push -u origin docs/*)",
      "Bash(git push -u origin test/*)",

      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm favicons:*)",
      "Bash(pnpm supabase:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm run:*)",

      "Bash(node -v)",
      "Bash(pnpm -v)",

      "PowerShell(*gh.exe pr view*)",
      "PowerShell(*gh.exe pr list*)",
      "PowerShell(*gh.exe pr create*)",
      "PowerShell(*gh.exe pr merge --auto*)",
      "PowerShell(*gh.exe pr checks*)",
      "PowerShell(*gh.exe pr diff*)",
      "PowerShell(*gh.exe run list*)",
      "PowerShell(*gh.exe run view*)",
      "PowerShell(*gh.exe api repos*)",

      "PowerShell(Set-Content -Path*)"
    ],
    "ask": [
      "Bash(git push origin main:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean -f:*)",
      "Bash(rm -rf:*)",
      "PowerShell(*gh.exe pr merge --merge*)",
      "PowerShell(*gh.exe pr merge --rebase*)",
      "PowerShell(*gh.exe pr close*)",
      "PowerShell(*gh.exe release*)",
      "PowerShell(Remove-Item -Recurse*)"
    ]
  }
}
