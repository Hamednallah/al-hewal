{
  "name": "al-hewal",
  "version": "0.1.0",
  "private": true,
  "description": "Bilingual (Arabic / English) corporate website and admin Command Center for Al Hewal Real Estate Development and Investment Company.",
  "license": "UNLICENSED",
  "author": "Al Hewal Real Estate Development and Investment Company",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hamednallah/al-hewal.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --project=a11y",
    "test:rls": "vitest run tests/integration/rls.test.ts",
    "audit:signatures": "pnpm audit signatures",
    "audit:deps": "pnpm audit --audit-level=high",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "15.5.18",
    "next-intl": "4.11.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "0.0.1",
    "zod": "4.4.3",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.105.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-config-next": "15.5.18",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
